# SignalReach AI environment template
# Copy this file to .env.local and fill in real values.

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Data provider
# Supported values: mock | brightdata | brightdata-serp
DATA_PROVIDER=mock

# Bright Data shared auth
BRIGHTDATA_API_TOKEN=your_brightdata_api_token_here

# Bright Data Web Scraper datasets
BRIGHTDATA_DATASET_LINKEDIN=gd_REPLACE_WITH_YOUR_LINKEDIN_DATASET_ID
BRIGHTDATA_DATASET_REDDIT=gd_REPLACE_WITH_YOUR_REDDIT_DATASET_ID
BRIGHTDATA_DATASET_NEWS=gd_REPLACE_WITH_YOUR_NEWS_DATASET_ID

# Bright Data SERP
BRIGHTDATA_SERP_ZONE=your_brightdata_serp_zone

# Optional app config
NEXT_PUBLIC_APP_URL=http://localhost:3000
